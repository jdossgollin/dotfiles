#!/usr/bin/env bash

BIN_NAME=$(basename "$0")
COMMAND_NAME=$1
SUB_COMMAND_NAME=$2

# Source platform detection functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(dirname "$SCRIPT_DIR")"
. "$DOTFILES_DIR/system/.function"

sub_help() {
  echo "Usage: $BIN_NAME <command>"
  echo
  echo "Commands:"
  echo "   clean            Clean up caches (brew/apt, conda, julia)"
  echo "   edit             Open dotfiles in IDE ($DOTFILES_IDE)"
  echo "   help             This help message"
  echo "   sync-secrets     Pull secrets from Dashlane vault to local files"
  echo "   themes           Update shell themes (oh-my-zsh, powerlevel10k)"
  echo "   update           Update packages and package managers"
  if is-macos; then
    echo "   dock             Apply macOS Dock settings"
    echo "   macos            Apply macOS system defaults"
  fi
}

sub_edit() {
  sh -c "$DOTFILES_IDE $DOTFILES_DIR"
}

sub_update() {
  if is-macos; then
    sudo softwareupdate -i -a
    brew update
    brew upgrade
    brew upgrade --cask --greedy
  elif is-apt-available; then
    sudo apt-get update
    sudo apt-get upgrade -y
    sudo apt-get autoremove -y
    if is-snap-available; then
      sudo snap refresh
    fi
  fi

  # Cross-platform updates
  command -v juliaup >/dev/null && juliaup update
  command -v conda >/dev/null && conda update -n base conda --yes
  command -v npm >/dev/null && npm update -g
}

sub_clean() {
  if is-macos && command -v brew >/dev/null; then
    brew cleanup --prune=all
  fi

  if is-apt-available; then
    sudo apt-get autoremove -y
    sudo apt-get autoclean -y
  fi

  command -v conda >/dev/null && conda clean --all --yes
  command -v juliaup >/dev/null && juliaup gc
}

sub_macos() {
  if ! is-macos; then
    echo "Error: 'macos' command is only available on macOS"
    return 1
  fi
  for DEFAULTS_FILE in "${DOTFILES_DIR}"/macos/defaults*.sh; do
    echo "Applying ${DEFAULTS_FILE}" && . "${DEFAULTS_FILE}"
  done
  echo "Done. Some changes may require a logout/restart to take effect."
}

sub_dock() {
  if ! is-macos; then
    echo "Error: 'dock' command is only available on macOS"
    return 1
  fi
  . "${DOTFILES_DIR}/macos/dock.sh" && echo "Dock reloaded."
}

sub_sync-secrets() {
  if ! command -v dcli >/dev/null 2>&1; then
    echo "Error: Dashlane CLI (dcli) is not installed"
    echo "  Install: brew install dashlane/tap/dashlane-cli"
    return 1
  fi

  echo "Syncing vault..."
  dcli sync

  local secrets_dir="$DOTFILES_DIR/secrets"
  local api_keys_file="$secrets_dir/.api_keys"
  local cdsapirc_file="$HOME/.cdsapirc"

  # --- secrets/.api_keys ---
  echo "Writing $api_keys_file..."
  {
    echo "# Auto-generated by 'dotfiles sync-secrets' from Dashlane vault"
    echo "# Do not edit manually — changes will be overwritten on next sync"
    echo ""

    local openai_key todoist_key
    openai_key="$(dcli note "OpenAI API" --output text 2>/dev/null)"
    if [[ -n "$openai_key" ]]; then
      echo "export OPENAI_API_KEY=\"$openai_key\""
    else
      echo "# Warning: 'OpenAI API' note not found in Dashlane"
      echo "# export OPENAI_API_KEY=\"\""
    fi

    echo ""
    todoist_key="$(dcli note "Todoist API" --output text 2>/dev/null)"
    if [[ -n "$todoist_key" ]]; then
      echo "export TODOIST_API_KEY=\"$todoist_key\""
    else
      echo "# Warning: 'Todoist API' note not found in Dashlane"
      echo "# export TODOIST_API_KEY=\"\""
    fi

    echo ""
    fireflies_key="$(dcli note "Fireflies API" --output text 2>/dev/null)"
    if [[ -n "$fireflies_key" ]]; then
      echo "export FIREFLIES_API_KEY=\"$fireflies_key\""
    else
      echo "# Warning: 'Fireflies API' note not found in Dashlane"
      echo "# export FIREFLIES_API_KEY=\"\""
    fi

    echo ""
    local zotero_block
    zotero_block="$(dcli note "Zotero API Key" --output text 2>/dev/null)"
    if [[ -n "$zotero_block" ]]; then
      echo "$zotero_block"
    else
      echo "# Warning: 'Zotero API Key' note not found in Dashlane"
    fi
  } > "$api_keys_file"
  chmod 600 "$api_keys_file"

  # --- ~/.cdsapirc ---
  echo "Writing $cdsapirc_file..."
  local cds_content
  cds_content="$(dcli note "CDS APIRC" --output text 2>/dev/null)"
  if [[ -n "$cds_content" ]]; then
    echo "$cds_content" > "$cdsapirc_file"
    chmod 600 "$cdsapirc_file"
  else
    echo "Warning: 'CDS APIRC' note not found in Dashlane"
  fi

  echo ""
  echo "Secrets synced. Run 'source ~/.zshrc' to reload API keys."
}

sub_themes() {
  echo "Updating shell themes..."

  # Update Oh My Zsh
  if [[ -d "$HOME/.oh-my-zsh" ]]; then
    echo "Updating Oh My Zsh..."
    git -C "$HOME/.oh-my-zsh" pull --rebase --stat origin master
  fi

  # Update Powerlevel10k
  P10K_DIR="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k"
  if [[ -d "$P10K_DIR" ]]; then
    echo "Updating Powerlevel10k..."
    git -C "$P10K_DIR" pull --rebase --stat origin master

    # Update gitstatus binary
    echo "Updating gitstatus..."
    "$P10K_DIR/gitstatus/install" -f
  fi

  echo ""
  echo "Theme updates complete. Run 'exec zsh' to reload."
}

case $COMMAND_NAME in
"" | "-h" | "--help")
  sub_help
  ;;
*)
  shift
  sub_${COMMAND_NAME} $@
  if [ $? = 127 ]; then
    echo "'$COMMAND_NAME' is not a known command or has errors." >&2
    sub_help
    exit 1
  fi
  ;;
esac
