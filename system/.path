# Use native zsh PATH deduplication (faster than awk)
typeset -U path

# Custom paths (system paths like /usr/bin are already in PATH)
prepend-path "$HOME/.local/bin"
prepend-path "$HOME/bin"
prepend-path "$DOTFILES_DIR/bin"

# Platform paths using $OSTYPE (zsh builtin, no fork)
if [[ "$OSTYPE" =~ ^darwin ]]; then
  BREW_PREFIX="$(get-brew-prefix 2>/dev/null || echo '/opt/homebrew')"
  prepend-path "${BREW_PREFIX}/opt/ruby/bin"
  prepend-path "/Library/TeX/texbin"
  # Homebrew bin/sbin added by brew shellenv in .zprofile
elif [[ "$OSTYPE" =~ ^linux ]]; then
  prepend-path "/snap/bin"
fi

export PATH

# Quarto - defer python lookup to avoid fork on every shell start
export QUARTO_PYTHON="${QUARTO_PYTHON:-}"
